{
  "name": "fukuflow",
  "private": true,
  "version": "0.0.0",
  "bin": "server/index.js",
  "pkg": {
    "assets": [
      "dist/**/*",
      "server/db/wealth.db",
      "node_modules/sqlite3/lib/binding/**/*",
      "node_modules/systray2/traybin/**/*",
      "server/logo.ico"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist-exe"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "package": "pkg . --compress GZip",
    "build:icon": "node scripts/generate_ico.js",
    "build:full": "npm run build:icon && npm run build && npm run package && node server/patch_exe.js",
    "test:server": "npm test --prefix server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=playwright.config.ts --debug"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "react-hot-toast": "^2.6.0",
    "sqlite3": "^6.0.1",
    "systray2": "^2.1.4",
    "uuid": "^13.0.0",
    "winreg": "^1.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "@yao-pkg/pkg": "^6.19.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "open": "^11.0.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.3"
  }
}
